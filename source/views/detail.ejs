<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <link rel="stylesheet" href="/public/css/detail.css">
</head>
<body>

    <% if (product) { %>
        <article>
            <h2><%= product.name %></h2> <span><%= product.artist %></span>
            <h4><%= product.price %></h4>

            <nav>
                <a href="/genero/" <%= product.genre %>>
                    <%= product.genre %>
                </a>
            </nav>
        </article>

    <% } else { %>
        <h2>No se encontró el producto
            <a href="/productos">Volver</a>
        </h2> 
        
    <% } %>
    

</body>
</html>