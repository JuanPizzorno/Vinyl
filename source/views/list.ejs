<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <link rel="stylesheet" href="/public/css/list.css">
</head>
<body>

    <% if (products.length > 0) { %>
        <ul>
            <% products.forEach(element => { %>
                <%- include('./partials/product.ejs', {element:element}) %>
            <% }) %>
        </ul>

    <% } else { %>
        <h2>No se encontró el producto</h2>
    <% } %>
    

</body>
</html>